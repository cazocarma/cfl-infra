# Back
PORT=4000
CORS_ORIGIN=http://localhost
AUTHN_JWT_SECRET=replace-with-a-long-random-dev-secret

# DB (usada por cfl-back)
# Para DB en compose con perfil "db": sqlserver
# Para DB local fuera de compose (host): host.docker.internal
DB_HOST=sqlserver
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=ChangeThisStrongPass!123
DB_NAME=ControlFletesDev

# SAP adapter (cargas on-demand Control de Fletes)
SAP_ADAPTER_BASE_URL=http://192.168.8.20:5080
SAP_ADAPTER_API_TOKEN=replace-with-sap-adapter-token
SAP_ADAPTER_DEFAULT_DESTINATION=PRD
SAP_ADAPTER_REQUEST_TIMEOUT_MS=125000
CFL_ETL_MAX_DATE_RANGE_DAYS=30

# SQL Server (solo si levantas el servicio sqlserver local)
MSSQL_SA_PASSWORD=ChangeThisStrongPass!123
MSSQL_PORT=1433
MSSQL_DB=ControlFletesDev
MSSQL_MEMORY_LIMIT_MB=1024
