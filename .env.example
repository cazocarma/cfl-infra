# ============================================================
# CFL — Variables de configuracion (back + infra)
# ============================================================
#
# Estructura (alineada con platform/.env.example):
#   1. COMUN    — vars iguales en dev/prd o con defaults dev-friendly.
#   2. SECRETS  — completar con los valores reales (<changeme>).
#   3. SOLO PRD — referencia. Los overrides reales los aplica
#                 docker-compose.prd.yml cuando CFL_ENV=prd. No hay que
#                 descomentar nada; los valores viven en el overlay.
#
# Seleccion de ambiente: CFL_ENV=dev|prd. El Makefile lee este valor y
# aplica el overlay `docker-compose.${CFL_ENV}.yml` automaticamente.
#
# En dev: NODE_ENV=development, OIDC URLs -> localhost, cookies relajadas,
# CORS_ORIGIN=http://localhost, bind mounts + hot reload.
#
# En prd: NODE_ENV=production, OIDC URLs -> IP LAN (192.168.18.18),
# cookies secure+strict, CORS_ORIGIN=http://192.168.18.18.
#
# CFL sigue usando JWT propia (AUTHN_JWT_SECRET). El bloque OIDC_* queda
# pre-provisionado para la futura migracion a BFF (patron de EST/CDC).
# ============================================================

# ============================================================
# 1. COMUN (dev y prd)
# ============================================================

# Ambiente: dev | prd. Default dev-friendly; el server tiene CFL_ENV=prd en su .env.
CFL_ENV=dev

# Puerto interno del back (el router de platform proxya :80 -> back:4000).
PORT=4000

# Log level. dev overlay lo pisa a "debug".
LOG_LEVEL=info

# ── SQL Server (DBCFL en el SQL compartido 192.168.8.24) ─────
# El mismo servidor se usa en dev y prd; cambia solo el usuario si hace falta.
DB_HOST=192.168.8.24
DB_PORT=1433
DB_NAME=DBCFL

# ── OIDC (cliente `cfl-back` en realm CFLRealm) — PRE-PROVISIONADO ──
# Hoy el back NO consume estos valores (usa AUTHN_JWT_SECRET). Se dejan
# completos para que la migracion a BFF sea solo de codigo, sin tocar .env.
# Las URLs publicas (ISSUER / REDIRECT / POST_LOGOUT) las pisa cada overlay
# con el host que corresponda (localhost en dev, IP LAN en prd).
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/CFLRealm/.well-known/openid-configuration
OIDC_CLIENT_ID=cfl-back
OIDC_SCOPES=openid profile email
OIDC_REQUIRED_ROLE=cfl-user

# ── Sesion BFF (Redis — platform_cache, DB 0 reservada para CFL) ──
# El cookie name es el mismo en ambos ambientes. SECURE/SAMESITE los pisa
# cada overlay.
SESSION_COOKIE_NAME=cfl.sid
SESSION_TTL_SECONDS=28800

# ── SAP ETL (sync on-demand via greenvic-sap-etl) ──
# Endpoint y destino son fijos; el token es secreto (seccion 2).
SAP_ETL_BASE_URL=http://192.168.8.24:5090
SAP_ETL_DEFAULT_DESTINATION=PRD
SAP_ETL_REQUEST_TIMEOUT_MS=125000
CFL_ETL_MAX_DATE_RANGE_DAYS=30

# ============================================================
# 2. SECRETS (completar con valores reales)
# ============================================================

# SQL Server — usuario con permisos CRUD sobre DBCFL.
DB_USER=<changeme>
DB_PASSWORD=<changeme>

# JWT propia del back (activa hoy). Min 32 bytes hex. Generar:
#   openssl rand -hex 32
AUTHN_JWT_SECRET=<changeme-hex-64>

# OIDC client secret. DEBE coincidir con platform/.env:CFL_BACK_CLIENT_SECRET
# (el keycloak-config-cli de platform inyecta el mismo valor al realm).
OIDC_CLIENT_SECRET=<changeme-hex-64>

# Redis session URL. El password va LITERAL (no se interpola via env_file).
# Copiar REDIS_PASSWORD desde platform/.env. Ejemplo:
#   SESSION_REDIS_URL=redis://:AbCd1234...@redis:6379/0
SESSION_REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0

# Secret para firmar la cookie de sesion. Generar: openssl rand -hex 32
SESSION_COOKIE_SECRET=<changeme-hex-64>

# Token de acceso al adapter greenvic-sap-etl.
SAP_ETL_API_TOKEN=<changeme>

# ============================================================
# 3. SOLO PRD (referencia — no editar aqui)
# ============================================================
#
# Los overrides de prd los aplica `docker-compose.prd.yml` al levantar el
# stack con CFL_ENV=prd. NO hay que descomentar nada en este archivo.
#
# Para referencia, estos son los valores que el overlay prd inyecta:
#
#   NODE_ENV=production
#   LOG_LEVEL=info
#   OIDC_ISSUER_URL=http://192.168.18.18:8080/realms/CFLRealm
#   OIDC_REDIRECT_URI=http://192.168.18.18:80/api/v1/auth/callback
#   OIDC_POST_LOGOUT_REDIRECT_URI=http://192.168.18.18:80/login
#   SESSION_COOKIE_SECURE=true
#   SESSION_COOKIE_SAMESITE=strict
#   CORS_ORIGIN=http://192.168.18.18
#
# Analogamente, los valores dev los inyecta docker-compose.dev.yml con
# localhost y cookies relajadas.
