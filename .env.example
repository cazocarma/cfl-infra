# ============================================================
# CFL — Variables de entorno
# ============================================================
# Copia este archivo a .env y completa los valores:
#   cp .env.example .env
# ============================================================

# --- Ambiente ------------------------------------------------
# prd | dev
CFL_ENV=
CFL_BACKEND_ALIAS=
CFL_FRONTEND_ALIAS=

# --- Node ----------------------------------------------------
# production | development
NODE_ENV=

# --- Back ----------------------------------------------------
PORT=4000
CORS_ORIGIN=
# Minimo 32 bytes. Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTHN_JWT_SECRET=

# --- DB (conexion remota usada por cfl-back) -----------------
DB_HOST=
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- SAP ETL (extracciones on-demand via Greenvic SAP ETL) ---
SAP_ETL_BASE_URL=
SAP_ETL_API_TOKEN=
SAP_ETL_DEFAULT_DESTINATION=PRD
SAP_ETL_REQUEST_TIMEOUT_MS=125000
CFL_ETL_MAX_DATE_RANGE_DAYS=30
