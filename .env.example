# ============================================================
# CFL — Variables de entorno (DEV)
# ============================================================
# Copia este archivo a .env y completa los valores sensibles:
#   cp .env.example .env
# ============================================================

# --- Ambiente ------------------------------------------------
CFL_ENV=dev
CFL_BACKEND_ALIAS=cfl-backend-dev
CFL_FRONTEND_ALIAS=cfl-frontend-dev

# --- Node ----------------------------------------------------
NODE_ENV=development

# --- Back ----------------------------------------------------
PORT=4000
CORS_ORIGIN=http://192.168.18.18:83
# Minimo 32 bytes. Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTHN_JWT_SECRET=

# --- DB (conexion remota usada por cfl-back) -----------------
DB_HOST=
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=DBCFL

# --- SAP ETL (extracciones on-demand via Greenvic SAP ETL) ---
SAP_ETL_BASE_URL=http://192.168.8.24:5090
SAP_ETL_API_TOKEN=
SAP_ETL_DEFAULT_DESTINATION=PRD
SAP_ETL_REQUEST_TIMEOUT_MS=125000
CFL_ETL_MAX_DATE_RANGE_DAYS=30
