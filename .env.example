# =============================================================================
# CFL — plantilla UNICA de entorno (compartida por back+front+infra).
# Copiar a .env (chmod 600) y completar los valores <changeme>.
# Alineada con platform/docs/PLATFORM_INTEGRATION_SPEC.md §10.
#
# CFL usa auth por JWT propia hoy. El bloque OIDC_* + SESSION_* de abajo queda
# pre-provisionado para la futura migracion a BFF: cuando CFL adopte el patron
# de EST, el back podra leerlos directamente. Hasta entonces son inertes.
#
# Un solo archivo cubre prd y dev. El Makefile aplica docker-compose.dev.yml
# como overlay cuando CFL_ENV=dev; en prd usa solo el base. El overlay pisa
# NODE_ENV=development, CORS_ORIGIN, OIDC_REDIRECT_URI y las cookies relajadas.
# =============================================================================

# ── Stack ──
CFL_ENV=prd                          # prd | dev. Decide project name y si se carga docker-compose.dev.yml.
NODE_ENV=production                  # Base prd. El overlay dev lo pisa a development.
LOG_LEVEL=info
PORT=4000

# ── SQL Server (DBCFL en el SQL compartido 192.168.8.24) ────────────────────
DB_HOST=192.168.8.24
DB_PORT=1433
DB_NAME=DBCFL
DB_USER=<changeme>
DB_PASSWORD=<changeme>

# ── Auth (JWT — propia del back, activa hoy) ────────────────────────────────
# Minimo 32 bytes hex. Generar: openssl rand -hex 32
AUTHN_JWT_SECRET=<changeme-hex-64>
CORS_ORIGIN=http://192.168.18.18     # prd. Dev overlay lo pisa a http://localhost.

# ── OIDC BFF (Keycloak — CFLRealm) — PRE-PROVISIONADO, INACTIVO ─────────────
# Estas vars quedan listas para la migracion a BFF (ver AUTH_STANDARD.md).
# Hoy el back NO las consume; cuando migre, eliminar AUTHN_JWT_SECRET y activar
# el bloque que sigue (identico al patron de est-infra/.env.example §10).
OIDC_ISSUER_URL=http://192.168.18.18:8080/realms/CFLRealm
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/CFLRealm/.well-known/openid-configuration
OIDC_CLIENT_ID=cfl-back
OIDC_CLIENT_SECRET=<changeme-hex-64>       # mismo valor que platform/.env:CFL_BACK_CLIENT_SECRET
OIDC_REDIRECT_URI=http://192.168.18.18:80/api/v1/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://192.168.18.18:80/login
OIDC_SCOPES=openid profile email
OIDC_REQUIRED_ROLE=cfl-user

# ── Sesion BFF (Redis — platform_cache, DB 0 reservada para CFL) — INACTIVO ─
SESSION_REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0
SESSION_COOKIE_NAME=cfl.sid
SESSION_COOKIE_SECRET=<changeme-hex-64>    # openssl rand -hex 32
SESSION_COOKIE_SECURE=true                 # prd. Dev overlay lo pisa a false.
SESSION_COOKIE_SAMESITE=strict             # prd. Dev overlay lo pisa a lax.
SESSION_TTL_SECONDS=28800

# ── SAP ETL (extracciones on-demand via greenvic-sap-etl) ───────────────────
SAP_ETL_BASE_URL=http://192.168.8.24:5090
SAP_ETL_API_TOKEN=<changeme>
SAP_ETL_DEFAULT_DESTINATION=PRD
SAP_ETL_REQUEST_TIMEOUT_MS=125000
CFL_ETL_MAX_DATE_RANGE_DAYS=30
