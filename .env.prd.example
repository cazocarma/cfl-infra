# ============================================================
# CFL — Variables de entorno para PRODUCCION (PRD)
# ============================================================
# Copia este archivo a .env y completa los valores reales:
#   cp .env.prd.example .env
# ============================================================

# --- Ambiente ------------------------------------------------
CFL_ENV=prd
CFL_BACKEND_ALIAS=cfl-backend
CFL_FRONTEND_ALIAS=cfl-frontend

# --- Node ----------------------------------------------------
NODE_ENV=production

# --- Back ----------------------------------------------------
PORT=4000
CORS_ORIGIN=http://192.168.18.18
# Minimo 32 bytes. Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTHN_JWT_SECRET=

# --- DB (conexion remota usada por cfl-back) -----------------
DB_HOST=
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=DBCFL

# --- SAP adapter (cargas on-demand Control de Fletes) --------
SAP_ADAPTER_BASE_URL=http://192.168.8.20:5080
SAP_ADAPTER_API_TOKEN=
SAP_ADAPTER_DEFAULT_DESTINATION=PRD
SAP_ADAPTER_REQUEST_TIMEOUT_MS=125000
CFL_ETL_MAX_DATE_RANGE_DAYS=30
